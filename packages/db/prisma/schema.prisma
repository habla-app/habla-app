generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MODELOS PRINCIPALES — Habla! App
// ==========================================

model Usuario {
  id           String    @id @default(cuid())
  email        String    @unique
  nombre       String
  // @handle público para ranking/inscritos. Registro formal (Abr 2026):
  // NOT NULL, único, 3-20 chars, regex ^[a-zA-Z0-9_]+$. Case-sensitive
  // para display (Gustavo ≠ gustavo en UI) pero unicidad case-insensitive
  // en app (chequeado con mode: 'insensitive' en cada query). Al crear
  // vía OAuth sin elegir handle se asigna un temporal "new_<hex>" y
  // usernameLocked=false — middleware fuerza a /auth/completar-perfil.
  username       String   @unique
  usernameLocked Boolean  @default(false) // true tras completar-perfil: @handle inmutable
  tycAceptadosAt DateTime? // timestamp de aceptación de T&C + mayoría de edad
  fechaNac     DateTime?
  ubicacion    String? // Ciudad / Región libre
  verificado   Boolean   @default(false)
  rol          Rol       @default(JUGADOR)
  // Lote 11 (May 2026): si false el perfil público en /comunidad/[username]
  // muestra estado "Este usuario tiene perfil privado" (no expone stats ni
  // historial). Default true — los usuarios existentes quedan visibles.
  perfilPublico Boolean  @default(true)
  // Lote E (May 2026): teléfono E.164 (+51XXXXXXXXX) capturado en checkout
  // Premium para enviar picks 1:1 vía WhatsApp Business API. Opcional —
  // suscriptores sin teléfono solo reciben los picks por el Channel manual.
  telefono     String?
  // Lote K v3.2 (May 2026): número Yape (E.164 sin +). Capturado SOLO al ganar
  // Top 10 mensual de la Liga Habla!. Decisión §1.3 del análisis: premio
  // publicitario, no renta laboral — datos mínimos, sin DNI, sin cuenta
  // bancaria, sin Reniec, sin cifrado especial.
  yapeNumero   String?
  creadoEn     DateTime  @default(now())
  deletedAt    DateTime? // Sub-Sprint 7: soft delete (anonimiza PII)
  // Campos requeridos por NextAuth Prisma Adapter
  emailVerified DateTime?
  image         String?

  tickets               Ticket[]
  cuentas               Account[]
  sesiones              Session[]
  preferenciasNotif     PreferenciasNotif?
  solicitudesElim       SolicitudEliminacion[]
  premiosMensuales      PremioMensual[]
  logErrores            LogError[]
  eventosAnalitica      EventoAnalitica[]
  clicksAfiliados       ClickAfiliado[]
  conversionesAfiliados ConversionAfiliado[]
  suscripciones         Suscripcion[]
  conversacionesBot     ConversacionBot[]

  @@map("usuarios")
}

// ==========================================
// Tablas NextAuth v5 — Prisma Adapter
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

enum Rol {
  JUGADOR
  ADMIN
}

model Partido {
  id              String        @id @default(cuid())
  externalId      String        @unique // ID de API-Football
  liga            String
  equipoLocal     String
  equipoVisita    String
  fechaInicio     DateTime
  estado          EstadoPartido @default(PROGRAMADO)
  golesLocal      Int?
  golesVisita     Int?
  btts            Boolean? // Ambos anotaron
  mas25Goles      Boolean? // Mas de 2.5 goles
  huboTarjetaRoja Boolean?
  round           String? // "Fecha 34", "Cuartos de final", "Fase de grupos · J1"
  venue           String? // "Goodison Park, Liverpool"
  creadoEn        DateTime      @default(now())

  // Snapshot persistente del estado en vivo del partido. Lo escribe el
  // poller cada 30s; lo lee el endpoint/SSR del minuto. Persistir en BD
  // (en vez de sólo Map in-memory) sobrevive restarts y cubre el caso de
  // múltiples réplicas de Railway leyendo desde cachés distintos.
  liveStatusShort String? // "1H" | "HT" | "2H" | "ET" | "BT" | "P" | "FT" | "AET" | "PEN" | ...
  liveElapsed     Int? // fixture.status.elapsed
  liveExtra       Int? // injury time (1H/2H)
  liveUpdatedAt   DateTime? // timestamp del último setLiveStatus — TTL 30 min

  // Lote K (May 2026) — Filtros del admin v3.2.
  //   - mostrarAlPublico (Filtro 1): si TRUE, el partido aparece en /las-fijas
  //     y dispara generación de AnalisisPartido. Default FALSE — todos los
  //     partidos importados quedan ocultos hasta curación manual.
  //   - elegibleLiga (Filtro 2): si TRUE, el partido entra en la pool de la
  //     Liga Habla! del mes (combinables por usuarios). Default FALSE.
  //   - visibilidadOverride: override de la regla de 7 días para listing
  //     /liga (forzar_visible / forzar_oculto / null=sigue regla 7d).
  mostrarAlPublico    Boolean              @default(false)
  elegibleLiga        Boolean              @default(false)
  visibilidadOverride VisibilidadOverride?

  // Lote V (May 2026) — Motor de captura de cuotas v3.2.
  //   - estadoCaptura: estado agregado del pipeline de captura para los 7
  //     scrapers de este partido. INACTIVA hasta que admin activa Filtro 1.
  //   - ultimaCapturaEn: timestamp del último ciclo de captura completo
  //     (sea total o parcial). Si null, el partido nunca tuvo captura.
  estadoCaptura       String               @default("INACTIVA")
  ultimaCapturaEn     DateTime?

  torneos          Torneo[]
  eventos          EventoPartido[]
  picksPremium     PickPremium[]
  analisisPartido  AnalisisPartido?
  cuotasCasa       CuotasCasa[]
  alertasCuota     AlertaCuota[]

  @@map("partidos")
}

enum VisibilidadOverride {
  forzar_visible
  forzar_oculto
}

model EventoPartido {
  id        String   @id @default(cuid())
  partidoId String
  partido   Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  tipo      String // GOL | TARJETA_AMARILLA | TARJETA_ROJA | SUSTITUCION | FIN_PARTIDO | HALFTIME | INICIO
  minuto    Int
  equipo    String // LOCAL | VISITA | NEUTRAL (para FIN_PARTIDO/HALFTIME)
  jugador   String?
  detalle   String?
  creadoEn  DateTime @default(now())

  @@index([partidoId, minuto])
  @@map("eventos_partido")
}

enum EstadoPartido {
  PROGRAMADO
  EN_VIVO
  FINALIZADO
  CANCELADO
}

model Torneo {
  id             String       @id @default(cuid())
  nombre         String
  tipo           TipoTorneo // Lote 2: etiqueta informativa (no afecta reglas)
  partidoId      String
  partido        Partido      @relation(fields: [partidoId], references: [id])
  estado         EstadoTorneo @default(ABIERTO)
  totalInscritos Int          @default(0)
  cierreAt       DateTime // Al kickoff (= partido.fechaInicio)
  creadoEn       DateTime     @default(now())

  tickets Ticket[]

  @@map("torneos")
}

// Plan v6 (Lote 4): el tipo de torneo es informativo (badge visual).
// La entrada, el rake, la distribucion y el cierre NO dependen del tipo.
enum TipoTorneo {
  EXPRESS
  ESTANDAR
  PREMIUM
  GRAN_TORNEO
}

enum EstadoTorneo {
  ABIERTO
  CERRADO
  EN_JUEGO
  FINALIZADO
  CANCELADO
}

model Ticket {
  id                 String        @id @default(cuid())
  usuarioId          String
  usuario            Usuario       @relation(fields: [usuarioId], references: [id])
  torneoId           String
  torneo             Torneo        @relation(fields: [torneoId], references: [id])
  // Las 5 predicciones
  predResultado      ResultadoPred // LOCAL | EMPATE | VISITA
  predBtts           Boolean
  predMas25          Boolean
  predTarjetaRoja    Boolean
  predMarcadorLocal  Int
  predMarcadorVisita Int
  // Puntuacion
  puntosTotal        Int           @default(0)
  puntosResultado    Int           @default(0)
  puntosBtts         Int           @default(0)
  puntosMas25        Int           @default(0)
  puntosTarjeta      Int           @default(0)
  puntosMarcador     Int           @default(0)
  // Posicion final asignada al cerrar el torneo (competition ranking).
  posicionFinal      Int?
  // Snapshot de puntosTotal en el momento de FT del torneo. Lote 5: el
  // leaderboard mensual lee de aquí (no de puntosTotal, que sigue mutando
  // si el motor reentra en un torneo ya finalizado por algún recálculo
  // raro). Backfill: tickets con posicionFinal NOT NULL recibieron
  // `puntosFinales = puntosTotal` en la migración.
  puntosFinales      Int?
  // Lote K v3.2 (May 2026): contador de ediciones. El usuario puede editar
  // su combinada hasta el kickoff (decisión §4.9.5 del análisis). Cada
  // PUT /api/v1/tickets/[id] incrementa este contador. Alimenta el KPI
  // "ediciones promedio por combinada" del dashboard del Lote O. Default 0
  // — los tickets viejos quedan en 0 hasta su próxima edición.
  numEdiciones       Int           @default(0)
  creadoEn           DateTime      @default(now())

  // Un usuario no puede tener 2 tickets identicos en el mismo torneo
  // (regla legacy del Lote 0).
  @@unique([usuarioId, torneoId, predResultado, predBtts, predMas25, predTarjetaRoja, predMarcadorLocal, predMarcadorVisita])
  // Lote K v3.2: una combinada por jugador por torneo (decisión §4.9.1 del
  // análisis). En v3.2 cada Torneo representa exactamente un Partido elegible
  // de la Liga Habla! del mes, por lo que (usuarioId, torneoId) implica
  // (usuarioId, partidoId). Esta restricción bloquea a nivel BD que un
  // usuario tenga dos tickets activos para el mismo partido — incluso si por
  // un bug del frontend se intentara, la BD lo rechaza. La unique anterior
  // (con todas las predicciones) queda redundante pero no se elimina para
  // mantener migración aditiva pura.
  @@unique([usuarioId, torneoId])
  @@map("tickets")
}

enum ResultadoPred {
  LOCAL
  EMPATE
  VISITA
}

// ==========================================
// Sub-Sprint 7 — Perfil
// ==========================================

model PreferenciasNotif {
  usuarioId         String   @id
  usuario           Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  // 7 toggles según §10.8 del mockup
  notifInicioTorneo Boolean  @default(true) // Inicio de torneos
  notifResultados   Boolean  @default(true) // Resultados / puntuación final
  notifPremios      Boolean  @default(true) // Premios ganados
  notifSugerencias  Boolean  @default(true) // Sugerencias de torneos
  notifCierreTorneo Boolean  @default(true) // Cierre próximo / recordatorios
  notifPromos       Boolean  @default(false) // Novedades / promos (opt-in) — newsletter editorial / afiliados
  // Lote 10 (May 2026): digest semanal opt-out (default true). El cron L
  // genera el draft los sábados, el admin aprueba desde /admin/newsletter
  // y se envía a unión {SuscriptorNewsletter confirmados, usuarios con
  // notifSemanal=true y email verificado}.
  notifSemanal      Boolean  @default(true)
  // emailSemanal: legacy del Lote 1 (default false) — superado por
  // notifSemanal. Se conserva por compatibilidad de datos hasta cleanup
  // posterior; ningún caller lo usa más a partir de Lote 10.
  emailSemanal      Boolean  @default(false)
  // Lote E (May 2026): toggles Premium. Default true — los suscriptores
  // reciben picks y alertas en vivo por bot WhatsApp 1:1 (además del
  // Channel). Opt-out desde /perfil/preferencias.
  notifPremiumPicks       Boolean  @default(true)
  notifPremiumAlertasVivo Boolean  @default(true)
  actualizadoEn     DateTime @default(now()) @updatedAt

  @@map("preferencias_notif")
}

model SolicitudEliminacion {
  id          String    @id @default(cuid())
  usuarioId   String
  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  token       String    @unique // 32 bytes random para link de confirmación
  expiraEn    DateTime // 48h
  confirmadaEn DateTime?
  creadoEn    DateTime  @default(now())

  @@map("solicitudes_eliminacion")
}

// Lote 7: Log persistente de cada intento de backup. La fila singleton más
// reciente decide si el job de hoy ya corrió. Lote 4 (Abr 2026) eliminó
// la alerta de email por 2 fallos consecutivos junto con el resto de la
// maquinaria contable; el log sigue alimentando el check de `/api/health`.
model BackupLog {
  id           String   @id @default(cuid())
  fechaIntento DateTime @default(now())
  ok           Boolean
  archivo      String?
  bytes        Int?
  durationMs   Int?
  errorMsg     String?

  @@index([fechaIntento])
  @@map("backup_logs")
}

// ==========================================
// Lote 5 (May 2026) — Competencia mensual
// ==========================================
//
// Reemplaza al sistema de premios por torneo (demolido junto con Lukas en
// Lote 2). El nuevo modelo: cada mes calendario forma un leaderboard que
// agrega `puntosFinales` por usuario sobre los tickets de torneos
// finalizados del mes en curso. El día 1 del mes siguiente, un cron cierra
// el leaderboard del mes pasado, snapshotea el top 100 en JSONB y crea
// los registros de PremioMensual para el top 10 (S/ 1,250 totales).

model Leaderboard {
  id            String          @id @default(cuid())
  mes           String          @unique // formato YYYY-MM (ej. "2026-04")
  cerradoEn     DateTime?
  // Snapshot del top 100 al cierre. Forma:
  //   [{ userId: string, username: string, puntos: number, posicion: number }]
  // null mientras está abierto (para meses pasados; el mes en curso se
  // calcula on-the-fly y nunca se persiste hasta el cierre).
  posiciones    Json?
  totalUsuarios Int             @default(0)
  creadoEn      DateTime        @default(now())

  premios       PremioMensual[]

  @@map("leaderboards")
}

model PremioMensual {
  id            String      @id @default(cuid())
  leaderboardId String
  leaderboard   Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  posicion      Int
  userId        String
  usuario       Usuario     @relation(fields: [userId], references: [id])
  montoSoles    Int
  // Estado del pago. Valores válidos: PENDIENTE | COORDINADO | PAGADO | CANCELADO.
  // Default PENDIENTE; transiciones manuales desde /admin/premios-mensuales.
  estado        String      @default("PENDIENTE")
  // Datos de pago cuando el ganador responde el email. Forma libre por
  // ahora ({ tipo: "yape"|"plin"|"transferencia", numero?, banco?, cuenta?,
  // titular?, dni? }). Se formaliza en Lote 12 con Zod si crece.
  datosPago     Json?
  pagadoEn      DateTime?
  notas         String?
  creadoEn      DateTime    @default(now())

  @@index([leaderboardId])
  @@index([userId])
  @@index([estado])
  @@map("premios_mensuales")
}

// ==========================================
// Lote 6 (May 2026) — Logs + analytics in-house
// ==========================================
//
// Reemplaza a Sentry + PostHog (eliminados en Lote 1). Dos tablas:
//
//   - log_errores       errores y warnings persistidos por el logger Pino
//                       (level=error|critical) o llamados directos del
//                       service. Alimenta /admin/logs y el cron M (alertas
//                       críticas por email cada 1h con anti-spam).
//   - eventos_analitica eventos de producto/UX. El handler POST /api/v1/
//                       analytics/track inserta fire-and-forget. Cliente
//                       respeta el toggle "Analíticas" del cookie banner;
//                       eventos server-side ignoran el toggle.
//
// userId queda opcional en ambas tablas (errores de cron pre-login,
// eventos $pageview anónimos). Al borrar al usuario se hace SET NULL para
// preservar las series temporales sin re-crear PII.

model LogError {
  id        String   @id @default(cuid())
  level     String   // warn | error | critical
  source    String   // "api:tickets" | "cron:cierre-leaderboard" | etc.
  message   String
  stack     String?
  userId    String?
  usuario   Usuario? @relation(fields: [userId], references: [id], onDelete: SetNull)
  metadata  Json?
  creadoEn  DateTime @default(now())

  @@index([level, creadoEn(sort: Desc)])
  @@map("log_errores")
}

model EventoAnalitica {
  id        String   @id @default(cuid())
  evento    String   // "$pageview" | "signup_completed" | etc.
  userId    String?
  usuario   Usuario? @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?  // anónimo, generado en el cliente (Lote 6)
  props     Json?
  pais      String?  // ISO 3166-1 alpha-2 (header cf-ipcountry)
  userAgent String?
  pagina    String?  // ej. "/torneo/abc123"
  referrer  String?
  creadoEn  DateTime @default(now())

  // IP cruda nunca se persiste (la usamos in-memory sólo para rate-limit
  // del endpoint /api/v1/analytics/track). El country es lo único que
  // queremos cohort-ar geográficamente.

  @@index([evento, creadoEn(sort: Desc)])
  @@index([userId, creadoEn(sort: Desc)])
  @@map("eventos_analitica")
}

// ==========================================
// Lote 7 (May 2026) — Afiliación MINCETUR
// ==========================================
//
// Infraestructura de monetización por afiliación a casas de apuestas
// autorizadas por MINCETUR. Tres tablas:
//
//   - afiliados             catálogo de operadores (slug, urlBase, modelo
//                           de comisión, bono actual, rating, métodos de
//                           pago, pros/contras como JSONB).
//   - clicks_afiliados      1 fila por GET /go/[slug]; ipHash con SHA-256
//                           (IP cruda nunca se persiste), país de
//                           cf-ipcountry, userAgent, utm en JSONB.
//   - conversiones_afiliados registro manual de REGISTRO o FTD reportados
//                            por la casa (offline; carga manual desde
//                            /admin/conversiones).
//
// El redirect tracker `/go/[slug]` registra el click fire-and-forget y
// retorna 302 a `urlBase`. Si el slug no existe o `activo=false`, 404 con
// mensaje "Casa no disponible". Antes del redirect, el handler dispara
// `analyticsService.track('casa_click_afiliado', { afiliado, pagina_origen })`
// — ese evento es uno de los pasos del funnel del dashboard (Lote 6).

model Afiliado {
  id                          String   @id @default(cuid())
  slug                        String   @unique // "te-apuesto", "betsson"
  nombre                      String
  logoUrl                     String?
  autorizadoMincetur          Boolean  @default(true)
  urlBase                     String   // URL afiliada con tracking pixel
  // CPA | REVSHARE | HIBRIDO. String libre para que ampliar el set no
  // requiera migración (modelos de afiliación cambian seguido).
  modeloComision              String
  montoCpa                    Int?     // en S/, opcional
  porcentajeRevshare          Decimal? @db.Decimal(5, 2)
  bonoActual                  String?  // "100% hasta S/ 500"
  metodosPago                 String[] // ["Visa", "Yape", "Plin"]
  // pros / contras: array JSONB de strings cortos. Forma esperada:
  //   ["App muy estable", "Buen soporte 24/7"]
  pros                        Json?
  contras                     Json?
  rating                      Decimal? @db.Decimal(3, 2) // 4.50 sobre 5
  activo                      Boolean  @default(true)
  ordenDestacado              Int      @default(100) // menor = más arriba
  ultimaVerificacionMincetur  DateTime?
  // Lote 10 (May 2026): true cuando el cron K no pudo verificar al
  // afiliado (red caída, DOM cambió, fetch falló) y NO debe modificar
  // autorizadoMincetur/activo. El admin lo resuelve manualmente desde
  // /admin/afiliados/[id]. Se resetea a false en la próxima verificación
  // exitosa.
  verificacionPendiente       Boolean  @default(false)
  creadoEn                    DateTime @default(now())
  actualizadoEn               DateTime @default(now()) @updatedAt

  clicks       ClickAfiliado[]
  conversiones ConversionAfiliado[]
  picksPremium PickPremium[]
  comisiones   ComisionAfiliacion[]

  @@map("afiliados")
}

model ClickAfiliado {
  id         String   @id @default(cuid())
  afiliadoId String
  afiliado   Afiliado @relation(fields: [afiliadoId], references: [id], onDelete: Cascade)
  userId     String?
  usuario    Usuario? @relation(fields: [userId], references: [id], onDelete: SetNull)
  pagina     String   // referer (la page de Habla! desde donde se hizo click)
  utm        Json?    // { utm_source, utm_medium, utm_campaign, ... } parseado de query
  // SHA-256 del cf-connecting-ip / x-forwarded-for. Hash + sal por
  // proceso (sal in-memory, ver afiliacion.service). Sirve para
  // dedupe in-process sin re-identificar al usuario fuera del proceso.
  ipHash     String
  userAgent  String?
  pais       String?  // ISO 3166-1 alpha-2 (cf-ipcountry)
  creadoEn   DateTime @default(now())

  @@index([afiliadoId, creadoEn(sort: Desc)])
  @@map("clicks_afiliados")
}

model ConversionAfiliado {
  id            String   @id @default(cuid())
  afiliadoId    String
  afiliado      Afiliado @relation(fields: [afiliadoId], references: [id])
  userId        String?
  usuario       Usuario? @relation(fields: [userId], references: [id], onDelete: SetNull)
  // REGISTRO | FTD. String libre para sumar más tipos sin migración.
  tipo          String
  montoComision Decimal? @db.Decimal(10, 2)
  reportadoEn   DateTime
  notas         String?
  creadoEn      DateTime @default(now())

  @@index([afiliadoId, reportadoEn(sort: Desc)])
  @@map("conversiones_afiliados")
}

// ==========================================
// Lote 10 (May 2026) — Newsletter editorial
// ==========================================
//
// Dos tablas:
//
//   - suscriptores_newsletter   un email externo por fila. Flujo doble opt-in:
//                               POST /api/v1/newsletter/suscribir crea la
//                               fila SIN confirmadoEn y manda magic link.
//                               GET /api/v1/newsletter/confirmar?token=...
//                               setea confirmadoEn. unsubscribedEn lo setea
//                               GET /api/v1/newsletter/unsubscribe?token=...
//                               (sin login).
//   - digests_enviados          1 fila por semana ISO (YYYY-WW). El cron L
//                               crea la fila los sábados con `enviadoEn=null`
//                               y el `contenido` JSONB del digest. El admin
//                               aprueba desde /admin/newsletter; el endpoint
//                               admin envía a la unión de subscribers
//                               confirmados + usuarios con notifSemanal=true
//                               y email verificado, dedup por email.

model SuscriptorNewsletter {
  id              String    @id @default(cuid())
  email           String    @unique
  confirmadoEn    DateTime?
  unsubscribedEn  DateTime?
  // "footer" | "popup" | "leadmagnet" | "page-suscribir" | etc. Texto libre
  // para que ampliar fuentes no requiera migración.
  fuente          String?
  creadoEn        DateTime  @default(now())

  @@map("suscriptores_newsletter")
}

model DigestEnviado {
  id            String    @id @default(cuid())
  // YYYY-WW (ISO 8601 week date — semana del año). Único: 1 digest por
  // semana. La idempotencia del cron L vive acá.
  semana        String    @unique
  // JSONB del digest. Forma:
  //   { titulo, secciones: { topTipsters[], partidosTop[], articulosNuevos[],
  //     destacadoSemanaAnterior?, frase, ctas[] } }
  contenido     Json
  destinatarios Int       @default(0)
  enviadoEn     DateTime?
  // Email del admin que aprobó (no FK porque conservamos la traza incluso
  // si el admin se desvincula).
  aprobadoPor   String?
  creadoEn      DateTime  @default(now())

  @@map("digests_enviados")
}

// ==========================================
// Lote E (May 2026) — Premium WhatsApp Channel
// ==========================================
//
// Cuatro pilares:
//
//   - suscripciones        suscripción mensual/trimestral/anual a Premium.
//                          Una sola activa por usuario. Lifecycle:
//                          PENDIENTE → ACTIVA → CANCELANDO → VENCIDA. Pago
//                          con OpenPay BBVA; webhook activa la fila tras el
//                          primer cobro. Garantía 7 días con reembolso.
//   - pagos_suscripcion    histórico de cobros (primer cobro + recurrentes).
//                          1 fila por intento de cobro. Se cruza con OpenPay
//                          via `openpayCobroId` (UNIQUE). Estado del pago,
//                          últimos 4 dígitos, marca de tarjeta, etc.
//   - miembros_channel     espejo de la membresía en el WhatsApp Channel.
//                          Estado INVITADO/UNIDO/REINVITADO/REMOVIDO. WhatsApp
//                          Channels no expone API de gestión de miembros, por
//                          lo que la transición INVITADO→UNIDO la hace el cron
//                          de sync (asume UNIDO tras 24h sin re-trigger).
//   - picks_premium        picks generados por Claude API + aprobados por el
//                          editor antes de publicarse al Channel. Estado
//                          PENDIENTE → APROBADO/EDITADO_Y_APROBADO/RECHAZADO.
//                          Resultado post-partido (GANADO/PERDIDO/NULO/PUSH)
//                          lo marca el cron evaluador.
//
// Reglas duras (CLAUDE.md §14-19):
//   - Cero datos de tarjeta tocan BD (ni el servidor). Tokenización con
//     OpenPay.js client-side. Solo persistimos ultimosCuatro + marcaTarjeta.
//   - Verificación de firma obligatoria en webhook (OpenPay HMAC-SHA256).
//   - Idempotencia: webhook puede reintentar el mismo evento. Verificar
//     estado antes de mutar (`if (suscripcion.activa) return;`).
//   - Cero auto-publicación de picks. APROBACIÓN HUMANA obligatoria.

model Suscripcion {
  id                   String    @id @default(cuid())
  usuarioId            String
  usuario              Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // Plan elegido. Precio en céntimos de soles (4900, 11900, 39900).
  plan                 PlanPremium
  precio               Int

  // OpenPay tracking. `openpaySuscripcionId` único: una fila por
  // suscripción real en OpenPay. Customer es reusable: si el usuario se
  // resuscribe luego de cancelar, reusamos el customerId.
  openpaySuscripcionId String?   @unique
  openpayCustomerId    String?

  // Lifecycle. `activa` es atajo derivado: TRUE mientras el acceso al
  // Channel + bot esté vigente. Cron sync mantiene la coherencia.
  estado               EstadoSuscripcion @default(PENDIENTE)
  activa               Boolean   @default(false)
  cancelada            Boolean   @default(false)

  // Fechas críticas. `proximoCobro` es null si está cancelada (no más
  // cobros). `vencimiento` puede diferir de `proximoCobro` si el user
  // canceló: mantiene acceso hasta vencimiento sin nuevos cobros.
  iniciada             DateTime  @default(now())
  proximoCobro         DateTime?
  vencimiento          DateTime?
  canceladaEn          DateTime?
  motivoCancela        String?

  // Garantía 7 días. `enGarantia` se setea TRUE al crear; el cron sync
  // (o el endpoint admin de reembolso) lo flippea cuando vence el plazo.
  enGarantia           Boolean   @default(true)
  reembolsoPedido      Boolean   @default(false)
  reembolsoEn          DateTime?

  pagos                PagoSuscripcion[]
  miembrosChannel      MiembroChannel[]

  creadoEn             DateTime  @default(now())
  actualizadoEn        DateTime  @updatedAt

  @@index([usuarioId, activa])
  @@index([proximoCobro])
  @@index([estado, vencimiento])
  @@map("suscripciones")
}

enum PlanPremium {
  MENSUAL
  TRIMESTRAL
  ANUAL
}

enum EstadoSuscripcion {
  PENDIENTE   // Recién creada, esperando confirmación de pago vía webhook
  ACTIVA      // Pago confirmado, acceso vigente
  CANCELANDO  // Cancelada pero aún con acceso (hasta vencimiento)
  VENCIDA     // Vencida sin renovación (cobro recurrente falló o canceló)
  REEMBOLSADA // Reembolsada en garantía 7 días
  FALLIDA     // Pago falló y OpenPay agotó reintentos
}

model PagoSuscripcion {
  id              String    @id @default(cuid())
  suscripcionId   String
  suscripcion     Suscripcion @relation(fields: [suscripcionId], references: [id], onDelete: Cascade)

  // OpenPay tracking. UNIQUE para idempotencia del webhook.
  openpayCobroId  String    @unique
  openpayMetodo   String?            // 'card' | 'bank_account' | etc.

  monto           Int                 // céntimos de soles
  estado          EstadoPago
  intentos        Int       @default(1)

  fecha           DateTime  @default(now())
  acreditadoEn    DateTime?
  rechazadoEn     DateTime?

  // Datos de tarjeta para mostrar al usuario en /premium/mi-suscripcion
  // (NUNCA datos sensibles — solo display).
  ultimosCuatro   String?
  marcaTarjeta    String?
  codigoError     String?
  mensajeError    String?

  creadoEn        DateTime  @default(now())

  @@index([suscripcionId, fecha(sort: Desc)])
  @@map("pagos_suscripcion")
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  RECHAZADO
  REEMBOLSADO
  TIMEOUT
}

// Membresía en el WhatsApp Channel privado. Una suscripción ACTIVA debería
// tener exactamente 1 fila MiembroChannel cuyo estado refleje su acceso al
// Channel: INVITADO (envío link, esperando join), UNIDO (asumimos
// confirmado tras 24h o por click manual del admin), REINVITADO (re-envío
// del link tras N horas sin join), REMOVIDO (tras cancelación o churn).
model MiembroChannel {
  id              String    @id @default(cuid())
  suscripcionId   String
  suscripcion     Suscripcion @relation(fields: [suscripcionId], references: [id], onDelete: Cascade)
  // Denormalizado para queries rápidas sin join.
  usuarioId       String

  estado          EstadoMembresia @default(INVITADO)
  invitadoEn      DateTime  @default(now())
  unidoEn         DateTime?
  removidoEn      DateTime?

  // Tracking de envíos del invite link.
  invitesEnviados Int       @default(1)
  ultimoInviteAt  DateTime  @default(now())

  // Una sola fila ACTIVA por suscripción. Si el cron necesita transicionar
  // INVITADO → REINVITADO → UNIDO usa update (no insert). Si la suscripción
  // termina y vuelve a empezar, la nueva suscripción tendrá su propia fila.
  @@unique([suscripcionId, estado])
  @@index([usuarioId, estado])
  @@map("miembros_channel")
}

enum EstadoMembresia {
  INVITADO
  UNIDO
  REINVITADO
  REMOVIDO
}

model PickPremium {
  id                String    @id @default(cuid())
  partidoId         String
  partido           Partido   @relation(fields: [partidoId], references: [id], onDelete: Cascade)

  // Mercado y recomendación
  mercado           MercadoPick
  // String libre: para 1X2 ('home'|'draw'|'away'), BTTS ('btts_si'|'btts_no'),
  // OVER_UNDER_25 ('over'|'under'), TARJETA_ROJA ('roja_si'|'roja_no'),
  // MARCADOR_EXACTO ('1-0'|'2-1'|...).
  outcome           String
  cuotaSugerida     Float
  // Stake como fracción del bankroll (0.01-0.03 típicamente).
  stakeSugerido     Float
  // EV+ como fracción (0.05-0.30 típicamente). Null si no calculado.
  evPctSugerido     Float?

  // Casa con mejor cuota. Opcional — picks de mercados sin afiliado mapeado
  // o cuando ninguna casa tiene la cuota recomendada.
  casaRecomendadaId String?
  casaRecomendada   Afiliado? @relation(fields: [casaRecomendadaId], references: [id], onDelete: SetNull)

  // Razonamiento textual generado por Claude API. ~150 palabras esperadas.
  razonamiento      String   @db.Text
  // JSONB con stats clave que sustentan la recomendación. Forma esperada:
  //   { h2h: string, formaReciente: string, factorClave: string }
  // Pero string libre — el formato lo dicta el prompt y puede evolucionar.
  estadisticas      Json?

  // Fuente del pick. CLAUDE_API es la default (cron generador); EDITOR_MANUAL
  // queda para que el admin pueda crear picks a mano desde Lote F.
  generadoPor       FuentePick
  generadoEn        DateTime  @default(now())

  // Aprobación. `aprobado` es atajo derivado de `estado` para indexes y
  // queries rápidas. Cero auto-publicación: SIEMPRE pasa por humano.
  estado            EstadoPick @default(PENDIENTE)
  aprobado          Boolean    @default(false)
  aprobadoPor       String?
  aprobadoEn        DateTime?
  rechazadoMotivo   String?

  // Distribución al Channel + bot 1:1. `enviadoAlChannel` se setea cuando
  // al menos un envío 1:1 fue exitoso. El admin sigue copiando el mensaje
  // manualmente al Channel hasta que Meta libere API de Channels.
  enviadoAlChannel  Boolean   @default(false)
  enviadoEn         DateTime?
  channelMessageId  String?

  // Resultado post-partido. Lo marca el cron evaluador (cada hora) cuando
  // el partido pasa a FINALIZADO.
  resultadoFinal    ResultadoPick?
  evaluadoEn        DateTime?

  // Fecha base para ordenamiento en feed admin. Se setea al crear.
  fechaPublicacion  DateTime  @default(now())

  creadoEn          DateTime  @default(now())
  actualizadoEn     DateTime  @updatedAt

  @@index([partidoId, aprobado])
  @@index([estado, fechaPublicacion(sort: Desc)])
  @@index([aprobado, resultadoFinal])
  @@map("picks_premium")
}

enum MercadoPick {
  RESULTADO_1X2
  BTTS
  OVER_UNDER_25
  TARJETA_ROJA
  MARCADOR_EXACTO
}

enum FuentePick {
  CLAUDE_API
  EDITOR_MANUAL
}

enum EstadoPick {
  PENDIENTE
  APROBADO
  EDITADO_Y_APROBADO
  RECHAZADO
}

enum ResultadoPick {
  GANADO
  PERDIDO
  NULO
  PUSH
}

// Bot conversacional 1:1 vía WhatsApp Business API. Cada usuario que escriba
// al número del bot abre una `ConversacionBot`. La cerramos (cerrada=true)
// si el user no escribe en >7 días. Próximo mensaje del mismo número abre
// nueva conversación.
model ConversacionBot {
  id              String    @id @default(cuid())
  usuarioId       String?
  usuario         Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  // Phone E.164 — siempre presente (lo provee el webhook de WhatsApp).
  whatsappFrom    String
  ultimoMensajeAt DateTime  @default(now())
  cerrada         Boolean   @default(false)

  mensajes        MensajeBot[]
  creadoEn        DateTime  @default(now())

  @@index([whatsappFrom, cerrada])
  @@index([usuarioId, cerrada])
  @@map("conversaciones_bot")
}

model MensajeBot {
  id              String    @id @default(cuid())
  conversacionId  String
  conversacion    ConversacionBot @relation(fields: [conversacionId], references: [id], onDelete: Cascade)

  rol             RolMensaje
  contenido       String   @db.Text
  // ID en WhatsApp para correlacionar con webhooks de status.
  whatsappMsgId   String?

  // Metadata si el mensaje fue generado por IA (rol=ASSISTANT).
  generadoConIA   Boolean   @default(false)
  modeloIA        String?
  tokensUsados    Int?
  // Si el mensaje del bot incluyó marker [DERIVAR_HUMANO] en respuesta y
  // se notificó al admin por email.
  fueDerivado     Boolean   @default(false)

  creadoEn        DateTime  @default(now())

  @@index([conversacionId, creadoEn])
  @@map("mensajes_bot")
}

enum RolMensaje {
  USER
  ASSISTANT
}

// ==========================================
// Lote F (May 2026) — Auditoría admin
// ==========================================
//
// Registra cada acción admin destructiva o sensible (aprobar pick,
// cancelar suscripción, reembolsar, marcar premio pagado, editar campañas
// de newsletter, banear miembro, etc.). Regla 21 del CLAUDE.md:
// auditoría 100%, nunca se sample-ea.
//
// `actorId` queda NULLABLE: si el actor fue un cron one-shot autenticado
// con CRON_SECRET, no hay user real. `actorEmail` es la copia denormalizada
// para no perder rastro si el usuario admin se elimina luego.

model AuditoriaAdmin {
  id          String   @id @default(cuid())
  actorId     String?  // userId del admin que ejecutó la acción
  actorEmail  String?  // snapshot del email para preservar trazabilidad
  accion      String   // ej: "pick.aprobar", "suscripcion.cancelar", "premio.marcar_pagado"
  entidad     String   // ej: "PickPremium", "Suscripcion", "PremioMensual"
  entidadId   String?  // id del row mutado (cuando aplica)
  resumen     String?  // descripción breve human-readable
  metadata    Json?    // diff o contexto (ej: { motivo, montoOriginal, montoNuevo })
  creadoEn    DateTime @default(now())

  @@index([creadoEn(sort: Desc)])
  @@index([entidad, creadoEn(sort: Desc)])
  @@index([actorId, creadoEn(sort: Desc)])
  @@map("auditoria_admin")
}

// ==========================================
// Lote G (May 2026) — Admin desktop análisis
// ==========================================
//
// Seis modelos:
//
//   - metricas_vitales       Core Web Vitals (LCP/INP/CLS) capturados por
//                            web-vitals client lib. Sample 10% en cliente
//                            para no saturar BD bajo tráfico real.
//   - lighthouse_runs        Histórico de corridas Lighthouse (manual o
//                            cron semanal con PageSpeed Insights API).
//                            Score 0-100 por categoría + raw JSON.
//   - costos_operativos      Costos mensuales editables por admin
//                            (Anthropic, Resend, Railway, salarios, etc.)
//                            UNIQUE (mes, categoria). Monto en céntimos PEN.
//   - comisiones_afiliacion  Pagos de comisión que reportan las casas a
//                            Habla! mensualmente. UNIQUE (mes, afiliadoId).
//   - alarmas                Alarmas activas/desactivadas. Tipo (KPI /
//                            EVENTO_CRITICO / MANUAL) + severidad. CRITICAL
//                            dispara email; warn/info solo BD.
//   - alarmas_config         Thresholds editables por KPI. El cron
//                            evaluar-alarmas (1h) los lee, calcula valores
//                            actuales y crea/desactiva alarmas idempotente.

model MetricaVital {
  id              String   @id @default(cuid())
  // 'LCP' | 'INP' | 'CLS' | 'FCP' | 'TTFB' (Web Vitals oficiales).
  nombre          String
  // Valor en ms (LCP/INP/FCP/TTFB) o score sin unidad (CLS).
  valor           Float
  // Pathname de la página donde se midió. Ej. "/partidos/[slug]" reemplazado
  // por el real ej. "/partidos/manchester-vs-liverpool". Hard cap 200 chars.
  ruta            String
  // 'mobile' | 'desktop' | 'tablet' inferido del UA.
  deviceType      String?
  // '4g' | '3g' | 'wifi' | 'slow-2g' del Network Information API (best-effort).
  connectionType  String?
  // UA truncado para análisis ad-hoc; no PII.
  userAgent       String?
  fecha           DateTime @default(now())

  @@index([nombre, fecha(sort: Desc)])
  @@index([ruta, nombre, fecha(sort: Desc)])
  @@map("metricas_vitales")
}

model LighthouseRun {
  id              String   @id @default(cuid())
  ruta            String   // ej. "/", "/partidos/[slug]", "/comunidad", "/premium"
  device          String   // 'mobile' | 'desktop'
  // Scores 0-100 (PageSpeed Insights ya los normaliza).
  performance     Int
  accessibility   Int
  bestPractices   Int
  seo             Int
  // Métricas crudas en ms (LCP / INP / CLS si están disponibles).
  lcpMs           Int?
  inpMs           Int?
  cls             Float?
  // Origen de la corrida.
  origen          String   @default("cron") // 'cron' | 'manual'
  // Email del admin que disparó (manual) o null (cron).
  disparadoPor    String?
  // Notas opcionales (ej. "post-deploy de Lote G").
  notas           String?
  fecha           DateTime @default(now())

  @@index([ruta, device, fecha(sort: Desc)])
  @@index([fecha(sort: Desc)])
  @@map("lighthouse_runs")
}

model CostoOperativo {
  id            String    @id @default(cuid())
  // Formato YYYY-MM. Único por (mes, categoría) para idempotencia.
  mes           String
  // String libre: "anthropic_api" | "openpay_pasarela" | "whatsapp_api" |
  // "resend" | "railway" | "cloudflare" | "salarios" | "premios_liga" |
  // "marketing_paid" | "otros" | etc.
  categoria     String
  // Monto en céntimos PEN. 1 sol = 100. Permite Decimal-friendly sin Decimal.
  monto         Int
  notas         String?
  // userId del admin que registró el costo. Snapshot — no FK.
  registradoPor String?
  registradoEn  DateTime  @default(now())
  // Última edición (admin puede corregir post-cierre).
  editadoEn     DateTime  @updatedAt

  @@unique([mes, categoria])
  @@index([mes])
  @@map("costos_operativos")
}

model ComisionAfiliacion {
  id            String    @id @default(cuid())
  mes           String                  // YYYY-MM
  afiliadoId    String
  afiliado      Afiliado  @relation(fields: [afiliadoId], references: [id], onDelete: Cascade)
  // Monto pagado por la casa al banco de Habla! ese mes (céntimos PEN).
  monto         Int
  // FTDs reportados que dispararon esa comisión (informativo).
  ftdsContados  Int       @default(0)
  notas         String?
  registradoPor String?                  // userId del admin que registró
  registradoEn  DateTime  @default(now())

  @@unique([mes, afiliadoId])
  @@index([mes])
  @@index([afiliadoId, mes])
  @@map("comisiones_afiliacion")
}

model Alarma {
  id                  String         @id @default(cuid())
  tipo                TipoAlarma
  severidad           SeveridadAlarma
  titulo              String
  descripcion         String         @db.Text
  // ID del KPI cuando tipo=KPI_THRESHOLD. Ej. 'conv_visita_registro'.
  metricId            String?
  // Datos contextuales (ej. {valorActual, threshold, ventanaMin, source}).
  contexto            Json?
  // Lifecycle.
  activa              Boolean        @default(true)
  desactivadaEn       DateTime?
  desactivadaPor      String?              // null si auto-desactivada por cron
  motivoDesactivacion String?
  creadaEn            DateTime       @default(now())

  @@index([activa, severidad, creadaEn(sort: Desc)])
  @@index([metricId, activa])
  @@map("alarmas")
}

enum TipoAlarma {
  KPI_THRESHOLD
  EVENTO_CRITICO
  MANUAL
}

enum SeveridadAlarma {
  INFO
  WARNING
  CRITICAL
}

model AlarmaConfiguracion {
  id              String          @id @default(cuid())
  metricId        String          @unique     // ej. 'conv_visita_registro'
  // Etiqueta human-readable del KPI (snapshot, así no requiere lookup).
  metricLabel     String
  // thresholdMin: alarma si valor < min. thresholdMax: alarma si valor > max.
  // Ambos opcionales (algún KPI puede tener solo uno). Si los dos son null
  // → config inerte (skipped por el cron).
  thresholdMin    Float?
  thresholdMax    Float?
  // Duración en minutos que el valor debe estar fuera de threshold para
  // disparar. 60-180 razonable para KPIs estables; 0 = instantáneo.
  duracionMinutos Int             @default(60)
  severidad       SeveridadAlarma @default(WARNING)
  habilitada      Boolean         @default(true)
  // Resumen humano que se incluye en la descripción de la alarma cuando
  // dispara. Ej. "Conversión visita→registro cayó debajo de 2%".
  notasInternas   String?
  creadoEn        DateTime        @default(now())
  actualizadoEn   DateTime        @updatedAt

  @@index([habilitada, metricId])
  @@map("alarmas_config")
}

// ==========================================
// Lote K v3.2 (May 2026) — AnalisisPartido (objeto rico del motor)
// ==========================================
//
// Decisiones §1.1 y §1.2 del análisis-repo-vs-mockup-v3.2.md: una sola
// plantilla `/las-fijas/[slug]` con bloques condicionales según estado
// de auth (visitor / free / socios). Cero duplicación de datos: un único
// objeto rico por partido. PickPremium del canal WhatsApp lee de
// AnalisisPartido aprobado para componer su mensaje (Lote L).
//
// Diferencia con PickPremium (Lote E):
//   - PickPremium: pick simple para el canal WhatsApp. 1 mercado + razonamiento
//     corto + cuota recomendada. Distribuido 1:1.
//   - AnalisisPartido: objeto rico completo del análisis del partido.
//     1X2 + probabilidades + análisis básico + combinada óptima + razonamiento
//     detallado + análisis profundo de goles + análisis profundo de tarjetas
//     + mercados secundarios. Renderizado por bloques en /las-fijas/[slug].
//
// Reglas duras (CLAUDE.md §18, §22 y nuevas reglas v3.2):
//   - Cero auto-publicación: PENDIENTE → APROBADO/RECHAZADO via /admin/picks.
//   - promptVersion + inputsJSON OBLIGATORIOS: sin esto, el motor opera a
//     ciegas (no se puede comparar performance entre versiones de prompt
//     ni reproducir/debuggear un análisis individual).
//   - Si un partido se desactiva (Filtro 1 OFF) y tenía análisis aprobado,
//     pasa a ARCHIVADO. La URL pública responde HTTP 410 Gone (no 404)
//     para que Google retire la URL del índice limpiamente.

model AnalisisPartido {
  id           String  @id @default(cuid())
  partidoId    String  @unique
  partido      Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)

  // -------------------------------------------------------------------
  // Contenido generado por el motor (objeto rico)
  // -------------------------------------------------------------------
  // Free + Socios:
  pronostico1x2  String // 'LOCAL' | 'EMPATE' | 'VISITA'
  // Forma esperada: { local: number, empate: number, visita: number }
  // — probabilidades 0-1 que suman 1.
  probabilidades Json
  // Forma esperada: { mercado: 'LOCAL'|'EMPATE'|'VISITA', cuota: number,
  // casa: string }. Mejor cuota disponible al momento de la generación.
  mejorCuota     Json
  // Texto Markdown — visible Free+Socios. Cubre: forma reciente, H2H,
  // lesiones, contexto del partido. ~150-300 palabras.
  analisisBasico String @db.Text

  // Solo Socios:
  // Forma esperada: { mercados: [{ mercado, outcome, cuota }], cuotaTotal,
  // stake, evPlus }. Combinada recomendada con EV+ ≥ 5%.
  combinadaOptima     Json?
  // Razonamiento detallado del análisis. Markdown. ~300-500 palabras.
  razonamiento        String? @db.Text
  // Forma esperada: { goles_esperados_local, goles_esperados_visita,
  // explicacion: string, factores: [string] }.
  analisisGoles       Json?
  // Forma esperada: { tarjetas_esperadas_total, riesgo_roja: 'BAJO'|'MEDIO'|'ALTO',
  // explicacion: string, factores: [string] }.
  analisisTarjetas    Json?
  // Forma esperada: [{ mercado, cuota, value, casa }] — mercados con value
  // detectado (BTTS, ±2.5, marcador exacto, etc.) además del 1X2.
  mercadosSecundarios Json?

  // -------------------------------------------------------------------
  // Metadata operativa de aprobación
  // -------------------------------------------------------------------
  estado          EstadoAnalisis @default(PENDIENTE)
  // Versión del prompt usada para generar este análisis. Ej. 'v3.2.0'.
  // OBLIGATORIO desde el día 1 — ver §4.3 del análisis.
  promptVersion   String
  // Snapshot completo de inputs vistos por Claude API: cuotas implícitas,
  // xG promedio, H2H, lesiones reportadas, alineaciones probables, etc.
  // OBLIGATORIO desde el día 1 — permite reproducir/debuggear y comparar
  // performance del motor entre versiones de prompt.
  inputsJSON      Json
  generadoEn      DateTime       @default(now())
  aprobadoPor     String?
  aprobadoEn      DateTime?
  rechazadoMotivo String?
  // Si Filtro 1 se desactiva sobre un partido con análisis aprobado, el
  // análisis pasa a ARCHIVADO. La vista /las-fijas/[slug] responde 410 Gone.
  archivadoEn     DateTime?

  // -------------------------------------------------------------------
  // Telemetría del motor (alimenta /admin/motor en Lote P)
  // -------------------------------------------------------------------
  latenciaMs   Int?
  tokensInput  Int?
  tokensOutput Int?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([estado])
  @@index([generadoEn(sort: Desc)])
  @@map("analisis_partido")
}

enum EstadoAnalisis {
  PENDIENTE
  APROBADO
  RECHAZADO
  ARCHIVADO
}

// ==========================================
// Lote V (May 2026) — Motor de captura de cuotas
// ==========================================
//
// Sustituye al sistema previo de odds (api-football, 4 casas globales,
// ventana 24h) por captura empírica de las 7 casas peruanas que cubren
// ~86% del tráfico (Stake, Apuesta Total, Coolbet, Doradobet, Betano,
// Inkabet, Te Apuesto). Sin histórico de snapshots: sólo cuota actual +
// cuotaAnterior por mercado para detectar variaciones ≥5%.
//
// Decisiones cubiertas (ver docs/plan-tecnico-lote-v-motor-cuotas.md):
//   §3.1 — CuotasCasa: una fila por (partido, casa) con los 4 mercados
//   §3.2 — Partido.estadoCaptura + ultimaCapturaEn (arriba)
//   §3.3 — EventIdExterno: discovery automático con fallback manual
//   §3.4 — AliasEquipo: 18 equipos de Liga 1 con aliases por casa
//   §3.5 — AlertaCuota: variaciones ≥5% para revisar en admin
//   §3.6 — SaludScraper: estado por casa (SANO/DEGRADADO/BLOQUEADO)
//
// Desviación documentada: el plan dice AliasEquipo.equipoCanonicoId con
// FK a un modelo Equipo. Ese modelo NO existe en el repo (Partido usa
// equipoLocal/equipoVisita como strings). Para no agregar una 6ta tabla
// fuera del alcance "5 tablas nuevas", se persiste equipoCanonicoNombre
// como string (el nombre canónico ES el identificador). El matcher de
// scrapers compara strings normalizados.

model CuotasCasa {
  id             String  @id @default(cuid())
  partidoId      String
  partido        Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  casa           String // "stake" | "apuesta_total" | "coolbet" | "doradobet" | "betano" | "inkabet" | "te_apuesto"
  eventIdExterno String // ID del partido en la casa (alfanumérico para Inkabet)

  // === MERCADO 1: 1X2 ===
  cuotaLocal          Decimal? @db.Decimal(7, 3)
  cuotaLocalAnterior  Decimal? @db.Decimal(7, 3)
  cuotaEmpate         Decimal? @db.Decimal(7, 3)
  cuotaEmpateAnterior Decimal? @db.Decimal(7, 3)
  cuotaVisita         Decimal? @db.Decimal(7, 3)
  cuotaVisitaAnterior Decimal? @db.Decimal(7, 3)

  // === MERCADO 2: Doble Oportunidad ===
  cuota1X         Decimal? @db.Decimal(7, 3)
  cuota1XAnterior Decimal? @db.Decimal(7, 3)
  cuota12         Decimal? @db.Decimal(7, 3)
  cuota12Anterior Decimal? @db.Decimal(7, 3)
  cuotaX2         Decimal? @db.Decimal(7, 3)
  cuotaX2Anterior Decimal? @db.Decimal(7, 3)

  // === MERCADO 3: Total ±2.5 goles ===
  cuotaOver25          Decimal? @db.Decimal(7, 3)
  cuotaOver25Anterior  Decimal? @db.Decimal(7, 3)
  cuotaUnder25         Decimal? @db.Decimal(7, 3)
  cuotaUnder25Anterior Decimal? @db.Decimal(7, 3)

  // === MERCADO 4: BTTS ===
  cuotaBttsSi         Decimal? @db.Decimal(7, 3)
  cuotaBttsSiAnterior Decimal? @db.Decimal(7, 3)
  cuotaBttsNo         Decimal? @db.Decimal(7, 3)
  cuotaBttsNoAnterior Decimal? @db.Decimal(7, 3)

  // === Estado y trazabilidad ===
  estado           String // "OK" | "STALE" | "ERROR" | "BLOQUEADO" | "SIN_DATOS"
  ultimoIntento    DateTime
  ultimoExito      DateTime?
  errorMensaje     String?
  intentosFallidos Int       @default(0)

  capturadoEn DateTime @default(now())

  @@unique([partidoId, casa])
  @@index([partidoId])
  @@index([casa, estado])
  @@map("cuotas_casa")
}

model AlertaCuota {
  id        String  @id @default(cuid())
  partidoId String
  partido   Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)

  casa      String
  mercado   String // "1X2" | "DOBLE_OP" | "MAS_MENOS_25" | "BTTS"
  seleccion String // "local" | "empate" | "visita" | "1x" | "12" | "x2" | "over25" | "under25" | "btts_si" | "btts_no"

  cuotaAnterior Decimal @db.Decimal(7, 3)
  cuotaNueva    Decimal @db.Decimal(7, 3)
  variacionPct  Decimal @db.Decimal(7, 3)

  vistaPorAdmin Boolean  @default(false)
  detectadoEn   DateTime @default(now())

  @@index([partidoId, vistaPorAdmin])
  @@index([detectadoEn])
  @@map("alertas_cuota")
}

model SaludScraper {
  id                    String    @id @default(cuid())
  casa                  String    @unique
  estado                String // "SANO" | "DEGRADADO" | "BLOQUEADO"
  ultimaEjecucion       DateTime?
  ultimoExito           DateTime?
  diasConsecutivosError Int       @default(0)
  detalleError          String?

  actualizadoEn DateTime @updatedAt

  @@map("salud_scrapers")
}
