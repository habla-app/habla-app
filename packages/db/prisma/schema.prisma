generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MODELOS PRINCIPALES — Habla! App
// ==========================================

model Usuario {
  id           String    @id @default(cuid())
  email        String    @unique
  nombre       String
  // @handle público para ranking/inscritos. Registro formal (Abr 2026):
  // NOT NULL, único, 3-20 chars, regex ^[a-zA-Z0-9_]+$. Case-sensitive
  // para display (Gustavo ≠ gustavo en UI) pero unicidad case-insensitive
  // en app (chequeado con mode: 'insensitive' en cada query). Al crear
  // vía OAuth sin elegir handle se asigna un temporal "new_<hex>" y
  // usernameLocked=false — middleware fuerza a /auth/completar-perfil.
  username       String   @unique
  usernameLocked Boolean  @default(false) // true tras completar-perfil: @handle inmutable
  tycAceptadosAt DateTime? // timestamp de aceptación de T&C + mayoría de edad
  fechaNac     DateTime?
  ubicacion    String? // Ciudad / Región libre
  verificado   Boolean   @default(false)
  rol          Rol       @default(JUGADOR)
  creadoEn     DateTime  @default(now())
  deletedAt    DateTime? // Sub-Sprint 7: soft delete (anonimiza PII)
  // Campos requeridos por NextAuth Prisma Adapter
  emailVerified DateTime?
  image         String?

  tickets       Ticket[]
  cuentas       Account[]
  sesiones      Session[]
  preferenciasNotif PreferenciasNotif?
  solicitudesElim   SolicitudEliminacion[]

  @@map("usuarios")
}

// ==========================================
// Tablas NextAuth v5 — Prisma Adapter
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

enum Rol {
  JUGADOR
  ADMIN
}

model Partido {
  id              String        @id @default(cuid())
  externalId      String        @unique // ID de API-Football
  liga            String
  equipoLocal     String
  equipoVisita    String
  fechaInicio     DateTime
  estado          EstadoPartido @default(PROGRAMADO)
  golesLocal      Int?
  golesVisita     Int?
  btts            Boolean? // Ambos anotaron
  mas25Goles      Boolean? // Mas de 2.5 goles
  huboTarjetaRoja Boolean?
  round           String? // "Fecha 34", "Cuartos de final", "Fase de grupos · J1"
  venue           String? // "Goodison Park, Liverpool"
  creadoEn        DateTime      @default(now())

  // Snapshot persistente del estado en vivo del partido. Lo escribe el
  // poller cada 30s; lo lee el endpoint/SSR del minuto. Persistir en BD
  // (en vez de sólo Map in-memory) sobrevive restarts y cubre el caso de
  // múltiples réplicas de Railway leyendo desde cachés distintos.
  liveStatusShort String? // "1H" | "HT" | "2H" | "ET" | "BT" | "P" | "FT" | "AET" | "PEN" | ...
  liveElapsed     Int? // fixture.status.elapsed
  liveExtra       Int? // injury time (1H/2H)
  liveUpdatedAt   DateTime? // timestamp del último setLiveStatus — TTL 30 min

  torneos Torneo[]
  eventos EventoPartido[]

  @@map("partidos")
}

model EventoPartido {
  id        String   @id @default(cuid())
  partidoId String
  partido   Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  tipo      String // GOL | TARJETA_AMARILLA | TARJETA_ROJA | SUSTITUCION | FIN_PARTIDO | HALFTIME | INICIO
  minuto    Int
  equipo    String // LOCAL | VISITA | NEUTRAL (para FIN_PARTIDO/HALFTIME)
  jugador   String?
  detalle   String?
  creadoEn  DateTime @default(now())

  @@index([partidoId, minuto])
  @@map("eventos_partido")
}

enum EstadoPartido {
  PROGRAMADO
  EN_VIVO
  FINALIZADO
  CANCELADO
}

model Torneo {
  id             String       @id @default(cuid())
  nombre         String
  tipo           TipoTorneo // Lote 2: etiqueta informativa (no afecta reglas)
  partidoId      String
  partido        Partido      @relation(fields: [partidoId], references: [id])
  estado         EstadoTorneo @default(ABIERTO)
  totalInscritos Int          @default(0)
  cierreAt       DateTime // Al kickoff (= partido.fechaInicio)
  creadoEn       DateTime     @default(now())

  tickets Ticket[]

  @@map("torneos")
}

// Plan v6 (Lote 4): el tipo de torneo es informativo (badge visual).
// La entrada, el rake, la distribucion y el cierre NO dependen del tipo.
enum TipoTorneo {
  EXPRESS
  ESTANDAR
  PREMIUM
  GRAN_TORNEO
}

enum EstadoTorneo {
  ABIERTO
  CERRADO
  EN_JUEGO
  FINALIZADO
  CANCELADO
}

model Ticket {
  id                 String        @id @default(cuid())
  usuarioId          String
  usuario            Usuario       @relation(fields: [usuarioId], references: [id])
  torneoId           String
  torneo             Torneo        @relation(fields: [torneoId], references: [id])
  // Las 5 predicciones
  predResultado      ResultadoPred // LOCAL | EMPATE | VISITA
  predBtts           Boolean
  predMas25          Boolean
  predTarjetaRoja    Boolean
  predMarcadorLocal  Int
  predMarcadorVisita Int
  // Puntuacion
  puntosTotal        Int           @default(0)
  puntosResultado    Int           @default(0)
  puntosBtts         Int           @default(0)
  puntosMas25        Int           @default(0)
  puntosTarjeta      Int           @default(0)
  puntosMarcador     Int           @default(0)
  // Posicion final asignada al cerrar el torneo (competition ranking).
  posicionFinal      Int?
  creadoEn           DateTime      @default(now())

  // Un usuario no puede tener 2 tickets identicos en el mismo torneo
  @@unique([usuarioId, torneoId, predResultado, predBtts, predMas25, predTarjetaRoja, predMarcadorLocal, predMarcadorVisita])
  @@map("tickets")
}

enum ResultadoPred {
  LOCAL
  EMPATE
  VISITA
}

// ==========================================
// Sub-Sprint 7 — Perfil
// ==========================================

model PreferenciasNotif {
  usuarioId         String   @id
  usuario           Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  // 7 toggles según §10.8 del mockup
  notifInicioTorneo Boolean  @default(true) // Inicio de torneos
  notifResultados   Boolean  @default(true) // Resultados / puntuación final
  notifPremios      Boolean  @default(true) // Premios ganados
  notifSugerencias  Boolean  @default(true) // Sugerencias de torneos
  notifCierreTorneo Boolean  @default(true) // Cierre próximo / recordatorios
  notifPromos       Boolean  @default(false) // Novedades / promos (opt-in) — newsletter editorial / afiliados
  emailSemanal      Boolean  @default(false) // Resumen semanal (opt-in)
  actualizadoEn     DateTime @default(now()) @updatedAt

  @@map("preferencias_notif")
}

model SolicitudEliminacion {
  id          String    @id @default(cuid())
  usuarioId   String
  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  token       String    @unique // 32 bytes random para link de confirmación
  expiraEn    DateTime // 48h
  confirmadaEn DateTime?
  creadoEn    DateTime  @default(now())

  @@map("solicitudes_eliminacion")
}

// Lote 7: Log persistente de cada intento de backup. La fila singleton más
// reciente decide si el job de hoy ya corrió, y los últimos 2 rows deciden
// si dispara la alerta por email (2 fallos consecutivos).
model BackupLog {
  id           String   @id @default(cuid())
  fechaIntento DateTime @default(now())
  ok           Boolean
  archivo      String?
  bytes        Int?
  durationMs   Int?
  errorMsg     String?

  @@index([fechaIntento])
  @@map("backup_logs")
}

// ==========================================
// Lote 8 — Culqi mockeado + Contabilidad partida doble
// ==========================================

// Idempotencia del webhook Culqi. Cualquier payload entra una sola vez:
// `eventId @unique` revienta el segundo intento y el handler responde
// 200 OK silencioso (Culqi reintenta hasta tener un 2xx).
model EventoCulqi {
  id          String   @id @default(cuid())
  eventId     String   @unique
  tipo        String
  payload     Json
  procesadoEn DateTime @default(now())
  usuarioId   String?
  cargoId     String?

  @@index([procesadoEn])
  @@map("eventos_culqi")
}

enum TipoCuenta {
  ACTIVO
  PASIVO
  PATRIMONIO
  INGRESO
  GASTO
}

// Plan de cuentas. Seed inicial con 11 cuentas (Lote 8 §2.B). El saldo
// vive aquí denormalizado para evitar recalcular toda la historia en cada
// render del balance general; Job I cuadra `saldoActual` contra el ledger.
model CuentaContable {
  id          String         @id @default(cuid())
  codigo      String         @unique
  nombre      String
  tipo        TipoCuenta
  saldoActual Decimal        @db.Decimal(14, 2) @default(0)
  activa      Boolean        @default(true)
  creadaEn    DateTime       @default(now())

  lineas      AsientoLinea[]

  @@map("cuentas_contables")
}

model Asiento {
  id          String         @id @default(cuid())
  fecha       DateTime       @default(now())
  origenTipo  String
  origenId    String?
  descripcion String
  totalDebe   Decimal        @db.Decimal(14, 2)
  totalHaber  Decimal        @db.Decimal(14, 2)
  metadata    Json?

  lineas      AsientoLinea[]
  movimientosBanco MovimientoBancoEsperado[]

  @@index([fecha])
  @@index([origenTipo, origenId])
  @@map("asientos")
}

model AsientoLinea {
  id          String         @id @default(cuid())
  asientoId   String
  cuentaId    String
  debe        Decimal        @db.Decimal(14, 2) @default(0)
  haber       Decimal        @db.Decimal(14, 2) @default(0)
  descripcion String?

  asiento     Asiento        @relation(fields: [asientoId], references: [id])
  cuenta      CuentaContable @relation(fields: [cuentaId], references: [id])

  @@index([asientoId])
  @@index([cuentaId])
  @@map("asientos_lineas")
}

// Conciliación bancaria — esperado vs real.
model MovimientoBancoEsperado {
  id              String              @id @default(cuid())
  fecha           DateTime
  monto           Decimal              @db.Decimal(14, 2)
  descripcion     String
  asientoId       String
  conciliadoConId String?
  conciliadoEn    DateTime?

  asiento         Asiento              @relation(fields: [asientoId], references: [id])
  conciliadoCon   MovimientoBancoReal? @relation(fields: [conciliadoConId], references: [id])

  @@index([fecha])
  @@index([conciliadoConId])
  @@map("movimientos_banco_esperados")
}

model MovimientoBancoReal {
  id              String                       @id @default(cuid())
  fecha           DateTime
  monto           Decimal                      @db.Decimal(14, 2)
  descripcion     String
  referenciaBanco String?
  cargadoEn       DateTime                     @default(now())
  cargaId         String

  esperados       MovimientoBancoEsperado[]

  @@unique([fecha, monto, descripcion])
  @@index([fecha])
  @@index([cargaId])
  @@map("movimientos_banco_reales")
}

model CargaExtractoBanco {
  id               String   @id @default(cuid())
  cargadoEn        DateTime @default(now())
  archivoNombre    String
  filasTotales     Int
  filasInsertadas  Int
  filasDuplicadas  Int
  filasError       Int
  rangoFechaInicio DateTime
  rangoFechaFin    DateTime

  @@map("cargas_extracto_banco")
}

// Job I — log de auditoría contable (mismo patrón que BackupLog).
model AuditoriaContableLog {
  id             String   @id @default(cuid())
  fechaIntento   DateTime @default(now())
  ok             Boolean
  totalHallazgos Int
  errores        Int
  warns          Int
  resumen        Json

  @@index([fechaIntento])
  @@map("auditoria_contable_logs")
}
