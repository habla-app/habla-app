generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// MODELOS PRINCIPALES — Habla! App
// ==========================================

model Usuario {
  id           String    @id @default(cuid())
  email        String    @unique
  nombre       String
  // @handle público para ranking/inscritos. Registro formal (Abr 2026):
  // NOT NULL, único, 3-20 chars, regex ^[a-zA-Z0-9_]+$. Case-sensitive
  // para display (Gustavo ≠ gustavo en UI) pero unicidad case-insensitive
  // en app (chequeado con mode: 'insensitive' en cada query). Al crear
  // vía OAuth sin elegir handle se asigna un temporal "new_<hex>" y
  // usernameLocked=false — middleware fuerza a /auth/completar-perfil.
  username       String   @unique
  usernameLocked Boolean  @default(false) // true tras completar-perfil: @handle inmutable
  tycAceptadosAt DateTime? // timestamp de aceptación de T&C + mayoría de edad
  fechaNac     DateTime?
  ubicacion    String? // Ciudad / Región libre
  verificado   Boolean   @default(false)
  rol          Rol       @default(JUGADOR)
  creadoEn     DateTime  @default(now())
  deletedAt    DateTime? // Sub-Sprint 7: soft delete (anonimiza PII)
  // Campos requeridos por NextAuth Prisma Adapter
  emailVerified DateTime?
  image         String?

  tickets           Ticket[]
  cuentas           Account[]
  sesiones          Session[]
  preferenciasNotif PreferenciasNotif?
  solicitudesElim   SolicitudEliminacion[]
  premiosMensuales  PremioMensual[]

  @@map("usuarios")
}

// ==========================================
// Tablas NextAuth v5 — Prisma Adapter
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

enum Rol {
  JUGADOR
  ADMIN
}

model Partido {
  id              String        @id @default(cuid())
  externalId      String        @unique // ID de API-Football
  liga            String
  equipoLocal     String
  equipoVisita    String
  fechaInicio     DateTime
  estado          EstadoPartido @default(PROGRAMADO)
  golesLocal      Int?
  golesVisita     Int?
  btts            Boolean? // Ambos anotaron
  mas25Goles      Boolean? // Mas de 2.5 goles
  huboTarjetaRoja Boolean?
  round           String? // "Fecha 34", "Cuartos de final", "Fase de grupos · J1"
  venue           String? // "Goodison Park, Liverpool"
  creadoEn        DateTime      @default(now())

  // Snapshot persistente del estado en vivo del partido. Lo escribe el
  // poller cada 30s; lo lee el endpoint/SSR del minuto. Persistir en BD
  // (en vez de sólo Map in-memory) sobrevive restarts y cubre el caso de
  // múltiples réplicas de Railway leyendo desde cachés distintos.
  liveStatusShort String? // "1H" | "HT" | "2H" | "ET" | "BT" | "P" | "FT" | "AET" | "PEN" | ...
  liveElapsed     Int? // fixture.status.elapsed
  liveExtra       Int? // injury time (1H/2H)
  liveUpdatedAt   DateTime? // timestamp del último setLiveStatus — TTL 30 min

  torneos Torneo[]
  eventos EventoPartido[]

  @@map("partidos")
}

model EventoPartido {
  id        String   @id @default(cuid())
  partidoId String
  partido   Partido  @relation(fields: [partidoId], references: [id], onDelete: Cascade)
  tipo      String // GOL | TARJETA_AMARILLA | TARJETA_ROJA | SUSTITUCION | FIN_PARTIDO | HALFTIME | INICIO
  minuto    Int
  equipo    String // LOCAL | VISITA | NEUTRAL (para FIN_PARTIDO/HALFTIME)
  jugador   String?
  detalle   String?
  creadoEn  DateTime @default(now())

  @@index([partidoId, minuto])
  @@map("eventos_partido")
}

enum EstadoPartido {
  PROGRAMADO
  EN_VIVO
  FINALIZADO
  CANCELADO
}

model Torneo {
  id             String       @id @default(cuid())
  nombre         String
  tipo           TipoTorneo // Lote 2: etiqueta informativa (no afecta reglas)
  partidoId      String
  partido        Partido      @relation(fields: [partidoId], references: [id])
  estado         EstadoTorneo @default(ABIERTO)
  totalInscritos Int          @default(0)
  cierreAt       DateTime // Al kickoff (= partido.fechaInicio)
  creadoEn       DateTime     @default(now())

  tickets Ticket[]

  @@map("torneos")
}

// Plan v6 (Lote 4): el tipo de torneo es informativo (badge visual).
// La entrada, el rake, la distribucion y el cierre NO dependen del tipo.
enum TipoTorneo {
  EXPRESS
  ESTANDAR
  PREMIUM
  GRAN_TORNEO
}

enum EstadoTorneo {
  ABIERTO
  CERRADO
  EN_JUEGO
  FINALIZADO
  CANCELADO
}

model Ticket {
  id                 String        @id @default(cuid())
  usuarioId          String
  usuario            Usuario       @relation(fields: [usuarioId], references: [id])
  torneoId           String
  torneo             Torneo        @relation(fields: [torneoId], references: [id])
  // Las 5 predicciones
  predResultado      ResultadoPred // LOCAL | EMPATE | VISITA
  predBtts           Boolean
  predMas25          Boolean
  predTarjetaRoja    Boolean
  predMarcadorLocal  Int
  predMarcadorVisita Int
  // Puntuacion
  puntosTotal        Int           @default(0)
  puntosResultado    Int           @default(0)
  puntosBtts         Int           @default(0)
  puntosMas25        Int           @default(0)
  puntosTarjeta      Int           @default(0)
  puntosMarcador     Int           @default(0)
  // Posicion final asignada al cerrar el torneo (competition ranking).
  posicionFinal      Int?
  // Snapshot de puntosTotal en el momento de FT del torneo. Lote 5: el
  // leaderboard mensual lee de aquí (no de puntosTotal, que sigue mutando
  // si el motor reentra en un torneo ya finalizado por algún recálculo
  // raro). Backfill: tickets con posicionFinal NOT NULL recibieron
  // `puntosFinales = puntosTotal` en la migración.
  puntosFinales      Int?
  creadoEn           DateTime      @default(now())

  // Un usuario no puede tener 2 tickets identicos en el mismo torneo
  @@unique([usuarioId, torneoId, predResultado, predBtts, predMas25, predTarjetaRoja, predMarcadorLocal, predMarcadorVisita])
  @@map("tickets")
}

enum ResultadoPred {
  LOCAL
  EMPATE
  VISITA
}

// ==========================================
// Sub-Sprint 7 — Perfil
// ==========================================

model PreferenciasNotif {
  usuarioId         String   @id
  usuario           Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  // 7 toggles según §10.8 del mockup
  notifInicioTorneo Boolean  @default(true) // Inicio de torneos
  notifResultados   Boolean  @default(true) // Resultados / puntuación final
  notifPremios      Boolean  @default(true) // Premios ganados
  notifSugerencias  Boolean  @default(true) // Sugerencias de torneos
  notifCierreTorneo Boolean  @default(true) // Cierre próximo / recordatorios
  notifPromos       Boolean  @default(false) // Novedades / promos (opt-in) — newsletter editorial / afiliados
  emailSemanal      Boolean  @default(false) // Resumen semanal (opt-in)
  actualizadoEn     DateTime @default(now()) @updatedAt

  @@map("preferencias_notif")
}

model SolicitudEliminacion {
  id          String    @id @default(cuid())
  usuarioId   String
  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  token       String    @unique // 32 bytes random para link de confirmación
  expiraEn    DateTime // 48h
  confirmadaEn DateTime?
  creadoEn    DateTime  @default(now())

  @@map("solicitudes_eliminacion")
}

// Lote 7: Log persistente de cada intento de backup. La fila singleton más
// reciente decide si el job de hoy ya corrió. Lote 4 (Abr 2026) eliminó
// la alerta de email por 2 fallos consecutivos junto con el resto de la
// maquinaria contable; el log sigue alimentando el check de `/api/health`.
model BackupLog {
  id           String   @id @default(cuid())
  fechaIntento DateTime @default(now())
  ok           Boolean
  archivo      String?
  bytes        Int?
  durationMs   Int?
  errorMsg     String?

  @@index([fechaIntento])
  @@map("backup_logs")
}

// ==========================================
// Lote 5 (May 2026) — Competencia mensual
// ==========================================
//
// Reemplaza al sistema de premios por torneo (demolido junto con Lukas en
// Lote 2). El nuevo modelo: cada mes calendario forma un leaderboard que
// agrega `puntosFinales` por usuario sobre los tickets de torneos
// finalizados del mes en curso. El día 1 del mes siguiente, un cron cierra
// el leaderboard del mes pasado, snapshotea el top 100 en JSONB y crea
// los registros de PremioMensual para el top 10 (S/ 1,250 totales).

model Leaderboard {
  id            String          @id @default(cuid())
  mes           String          @unique // formato YYYY-MM (ej. "2026-04")
  cerradoEn     DateTime?
  // Snapshot del top 100 al cierre. Forma:
  //   [{ userId: string, username: string, puntos: number, posicion: number }]
  // null mientras está abierto (para meses pasados; el mes en curso se
  // calcula on-the-fly y nunca se persiste hasta el cierre).
  posiciones    Json?
  totalUsuarios Int             @default(0)
  creadoEn      DateTime        @default(now())

  premios       PremioMensual[]

  @@map("leaderboards")
}

model PremioMensual {
  id            String      @id @default(cuid())
  leaderboardId String
  leaderboard   Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  posicion      Int
  userId        String
  usuario       Usuario     @relation(fields: [userId], references: [id])
  montoSoles    Int
  // Estado del pago. Valores válidos: PENDIENTE | COORDINADO | PAGADO | CANCELADO.
  // Default PENDIENTE; transiciones manuales desde /admin/premios-mensuales.
  estado        String      @default("PENDIENTE")
  // Datos de pago cuando el ganador responde el email. Forma libre por
  // ahora ({ tipo: "yape"|"plin"|"transferencia", numero?, banco?, cuenta?,
  // titular?, dni? }). Se formaliza en Lote 12 con Zod si crece.
  datosPago     Json?
  pagadoEn      DateTime?
  notas         String?
  creadoEn      DateTime    @default(now())

  @@index([leaderboardId])
  @@index([userId])
  @@index([estado])
  @@map("premios_mensuales")
}
