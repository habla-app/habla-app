# ============================================
# Habla! - Variables de Entorno
# Copia este archivo como .env y llena los valores
# NUNCA commitear el archivo .env
# ============================================

# Base de datos
DATABASE_URL=postgresql://habla:habla@localhost:5432/habladb
REDIS_URL=redis://localhost:6379

# Auth (NextAuth v5 — Google OAuth + magic link via Resend)
# AUTH_SECRET también se usa para firmar el JWT del handshake WS (5 min TTL).
AUTH_SECRET=              # Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=          # Alias legacy — idéntico a AUTH_SECRET
NEXTAUTH_URL=http://localhost:3000
# Registro formal (Abr 2026): Google OAuth requerido (además del magic link).
# Crear credenciales en https://console.cloud.google.com/apis/credentials.
# Redirect URIs:
#   - http://localhost:3000/api/auth/callback/google
#   - https://habla-app-production.up.railway.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API Deportiva
API_FOOTBALL_KEY=          # RapidAPI key para API-Football
API_FOOTBALL_HOST=v3.football.api-sports.io

# ============================================
# Lote E (May 2026) — Premium WhatsApp Channel
# ============================================
#
# Pasarela OpenPay BBVA (suscripción recurrente). Crear cuenta en
# https://www.openpay.pe/, completar KYC, crear los 3 planes:
#   - plan_premium_mensual    S/ 49 / 30 días
#   - plan_premium_trimestral S/ 119 / 90 días
#   - plan_premium_anual      S/ 399 / 365 días
# Después copiar Merchant ID + claves del Dashboard → Configuración → API Keys.
OPENPAY_MERCHANT_ID=
OPENPAY_PRIVATE_KEY=
OPENPAY_PUBLIC_KEY=
OPENPAY_PRODUCTION=false           # 'true' en prod, 'false' o vacío = sandbox
OPENPAY_WEBHOOK_SECRET=             # secret aleatorio, mismo en OpenPay Dashboard

# WhatsApp Business API (Meta Cloud API) — bot 1:1 + envío de picks.
# Setup en https://business.facebook.com/. Verificación 2-7 días hábiles.
META_BUSINESS_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=             # System User Token permanente
WHATSAPP_VERIFY_TOKEN=             # aleatorio, igual en webhook config Meta
WHATSAPP_APP_SECRET=               # secret de la App de Meta para HMAC
WHATSAPP_CHANNEL_PREMIUM_INVITE_LINK=   # link público al Channel privado
WHATSAPP_BUSINESS_PHONE_NUMBER=    # número del bot en formato +51XXXXXXXXX

# Anthropic Claude API — generación de picks Premium + bot FAQ.
# Crear cuenta en https://console.anthropic.com/, agregar método de pago,
# configurar límite de gasto mensual (ej: $50/mes).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Email del admin para notificaciones del bot (derivaciones a humano,
# alerta de ludopatía, batch de usuarios a remover del Channel).
# Si está vacío, las notificaciones se loggean pero no se envían.
ADMIN_EMAIL=                       # ej. equipo@hablaplay.com

# ============================================
# Lote G (May 2026) — Admin desktop análisis
# ============================================
#
# Google PageSpeed Insights API — Lighthouse semanal automático contra
# las rutas críticas (/, /comunidad, /premium, /cuotas, /blog). OPCIONAL:
# si no se configura, el cron Lighthouse hace skip silencioso, pero los
# Core Web Vitals reales del cliente igual se capturan en
# `metricas_vitales` (vista /admin/mobile-vitals).
#
# Setup:
# 1. Ir a https://console.cloud.google.com/.
# 2. Crear proyecto (o usar uno existente).
# 3. APIs & Services → habilitar "PageSpeed Insights API".
# 4. Credenciales → Create Credentials → API key.
# 5. Restringir la key a "PageSpeed Insights API" para seguridad.
PAGESPEED_API_KEY=

# Notificaciones
RESEND_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
JWT_SECRET=                # Generar con: openssl rand -base64 32
NODE_ENV=development

# Cron — OPCIONAL. El cron principal (cerrar-torneos) vive in-process
# via apps/web/instrumentation.ts (setInterval cada 60s), no requiere
# configuración. CRON_SECRET sólo se usa si quieres proteger el
# endpoint HTTP /api/cron/cerrar-torneos para triggering manual.
CRON_SECRET=               # opcional · Generar con: openssl rand -base64 32

# Lote 6 (May 2026) — alertas operativas in-house. Si hay errores
# `level=critical` en la última hora, el cron M (instrumentation.ts)
# manda un email-resumen a esta dirección (anti-spam: máx 1/h).
# Si está vacío, el cron M no envía nada (pero los críticos siguen
# persistidos en `log_errores` y se ven en /admin/logs).
ADMIN_ALERT_EMAIL=         # ej. hablaplay@gmail.com

# Backups automatizados a R2 (Lote 7) — opcional en dev. Si falta alguna,
# el job se autodeshabilita (state="unconfigured" en /api/health).
# Credenciales en 1Password vault "Habla! Infra".
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=               # https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=habla-db-backups
